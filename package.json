{
  "name": "museeks",
  "productName": "Museeks",
  "version": "0.23.4",
  "description": "A simple, clean, and cross-platform music player.",
  "type": "module",
  "bugs": {
    "url": "https://github.com/martpie/museeks/issues"
  },
  "author": "Pierre de la Martinière <pierre.de.la.martiniere@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martpie/museeks"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "gen:types": "bash scripts/gen.sh",
    "gen:translations": "lingui extract --clean --overwrite",
    "test:typings": "tsc --noEmit --project ./tsconfig.json",
    "test:unit": "vitest run --project unit",
    "test:ui": "vitest run --project e2e",
    "test:ui:watch": "vitest watch --project e2e",
    "test:lint": "oxlint --type-aware --type-check",
    "test:format": "oxfmt --check",
    "test:format:fix": "oxfmt",
    "package:checksums": "bash scripts/checksum.sh",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run gen:translations && git add src/translations"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@lingui/core": "5.9.3",
    "@lingui/react": "5.9.3",
    "@stylexjs/stylex": "0.18.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.166.7",
    "@tanstack/react-virtual": "3.13.22",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "browserslist": "4.28.1",
    "eventemitter3": "5.0.4",
    "lodash-es": "4.17.23",
    "nanoid": "5.1.6",
    "normalize.css": "8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-keybinding-component": "2.3.1",
    "semver": "7.7.4",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@lingui/babel-plugin-lingui-macro": "5.9.3",
    "@lingui/cli": "5.9.3",
    "@lingui/vite-plugin": "5.9.3",
    "@rolldown/plugin-babel": "0.2.1",
    "@stylexjs/eslint-plugin": "0.18.1",
    "@stylexjs/unplugin": "0.18.1",
    "@tanstack/router-plugin": "1.166.7",
    "@tauri-apps/cli": "2.10.1",
    "@types/babel__core": "7.20.5",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.0",
    "lightningcss": "1.32.0",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.16.0",
    "playwright": "1.58.2",
    "simple-git-hooks": "2.13.1",
    "vite": "8.0.0",
    "vite-plugin-svgr": "4.5.0",
    "vitest": "4.1.0",
    "vitest-browser-react": "2.1.0"
  },
  "trustedDependencies": [
    "esbuild",
    "oxfmt",
    "oxlint"
  ],
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22 <25",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10 <12",
      "onFail": "warn"
    }
  },
  "packageManager": "npm@11.11.1"
}
