{
  "name": "museeks",
  "version": "0.23.4",
  "description": "A simple, clean, and cross-platform music player.",
  "bugs": {
    "url": "https://github.com/martpie/museeks/issues"
  },
  "license": "MIT",
  "author": "Pierre de la Martinière <pierre.de.la.martiniere@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/martpie/museeks"
  },
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "tauri": "tauri",
    "gen:types": "bash scripts/gen.sh",
    "gen:translations": "lingui extract --clean --overwrite",
    "test:typings": "tsc --noEmit --project ./tsconfig.json",
    "package:checksums": "bash scripts/checksum.sh",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "postinstall": "simple-git-hooks",
    "knip": "knip"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@lingui/core": "6.0.0",
    "@lingui/react": "6.0.0",
    "@stylexjs/stylex": "0.18.3",
    "@tanstack/react-query": "5.100.6",
    "@tanstack/react-router": "1.168.25",
    "@tanstack/react-virtual": "3.13.24",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@tauri-apps/plugin-fs": "2.5.0",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "browserslist": "4.28.2",
    "eventemitter3": "5.0.4",
    "lodash-es": "4.18.1",
    "nanoid": "5.1.9",
    "normalize.css": "8.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-keybinding-component": "2.3.1",
    "semver": "7.7.4",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@lingui/babel-plugin-lingui-macro": "6.0.0",
    "@lingui/cli": "6.0.0",
    "@lingui/vite-plugin": "6.0.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@stylexjs/eslint-plugin": "0.18.3",
    "@stylexjs/unplugin": "0.18.3",
    "@tanstack/router-plugin": "1.167.28",
    "@tauri-apps/cli": "2.10.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "lightningcss": "1.32.0",
    "playwright": "1.59.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "vite": "catalog:",
    "vite-plugin-svgr": "5.2.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "2.2.0"
  },
  "simple-git-hooks": {
